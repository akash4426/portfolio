<svg width="800" height="600" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="grad1" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#1e293b;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#0f172a;stop-opacity:1" />
    </linearGradient>
    <linearGradient id="gold" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" style="stop-color:#d4af37;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#f4d03f;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <!-- Background -->
  <rect width="800" height="600" fill="url(#grad1)"/>
  
  <!-- Grid Pattern -->
  <pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse">
    <path d="M 40 0 L 0 0 0 40" fill="none" stroke="#334155" stroke-width="0.5" opacity="0.3"/>
  </pattern>
  <rect width="800" height="600" fill="url(#grid)"/>
  
  <!-- Central Server -->
  <g transform="translate(400, 280)">
    <rect x="-60" y="-80" width="120" height="160" rx="10" fill="#0f172a" stroke="url(#gold)" stroke-width="4"/>
    <rect x="-50" y="-60" width="100" height="15" rx="5" fill="#d4af37" opacity="0.3"/>
    <rect x="-50" y="-35" width="100" height="15" rx="5" fill="#d4af37" opacity="0.3"/>
    <rect x="-50" y="-10" width="100" height="15" rx="5" fill="#d4af37" opacity="0.3"/>
    <rect x="-50" y="15" width="100" height="15" rx="5" fill="#d4af37" opacity="0.5"/>
    <rect x="-50" y="40" width="100" height="15" rx="5" fill="#d4af37" opacity="0.3"/>
    <circle cx="0" cy="0" r="15" fill="#d4af37"/>
    <text x="0" y="6" font-family="Arial, sans-serif" font-size="14" font-weight="bold" fill="#0f172a" text-anchor="middle">FL</text>
  </g>
  
  <!-- Client Nodes -->
  <!-- Top Left -->
  <g transform="translate(150, 120)">
    <rect x="-40" y="-40" width="80" height="80" rx="10" fill="#1e293b" stroke="#d4af37" stroke-width="2"/>
    <circle cx="0" cy="-15" r="12" fill="#d4af37" opacity="0.5"/>
    <rect x="-20" y="5" width="40" height="5" rx="2" fill="#475569"/>
    <rect x="-20" y="15" width="30" height="5" rx="2" fill="#475569"/>
    <rect x="-20" y="25" width="35" height="5" rx="2" fill="#475569"/>
  </g>
  
  <!-- Top Right -->
  <g transform="translate(650, 120)">
    <rect x="-40" y="-40" width="80" height="80" rx="10" fill="#1e293b" stroke="#d4af37" stroke-width="2"/>
    <circle cx="0" cy="-15" r="12" fill="#d4af37" opacity="0.5"/>
    <rect x="-20" y="5" width="40" height="5" rx="2" fill="#475569"/>
    <rect x="-20" y="15" width="30" height="5" rx="2" fill="#475569"/>
    <rect x="-20" y="25" width="35" height="5" rx="2" fill="#475569"/>
  </g>
  
  <!-- Bottom Left -->
  <g transform="translate(150, 440)">
    <rect x="-40" y="-40" width="80" height="80" rx="10" fill="#1e293b" stroke="#d4af37" stroke-width="2"/>
    <circle cx="0" cy="-15" r="12" fill="#d4af37" opacity="0.5"/>
    <rect x="-20" y="5" width="40" height="5" rx="2" fill="#475569"/>
    <rect x="-20" y="15" width="30" height="5" rx="2" fill="#475569"/>
    <rect x="-20" y="25" width="35" height="5" rx="2" fill="#475569"/>
  </g>
  
  <!-- Bottom Right -->
  <g transform="translate(650, 440)">
    <rect x="-40" y="-40" width="80" height="80" rx="10" fill="#1e293b" stroke="#d4af37" stroke-width="2"/>
    <circle cx="0" cy="-15" r="12" fill="#d4af37" opacity="0.5"/>
    <rect x="-20" y="5" width="40" height="5" rx="2" fill="#475569"/>
    <rect x="-20" y="15" width="30" height="5" rx="2" fill="#475569"/>
    <rect x="-20" y="25" width="35" height="5" rx="2" fill="#475569"/>
  </g>
  
  <!-- Connection Lines with arrows -->
  <line x1="200" y1="140" x2="340" y2="220" stroke="#d4af37" stroke-width="2" stroke-dasharray="5,5" opacity="0.6"/>
  <line x1="600" y1="140" x2="460" y2="220" stroke="#d4af37" stroke-width="2" stroke-dasharray="5,5" opacity="0.6"/>
  <line x1="200" y1="420" x2="340" y2="340" stroke="#d4af37" stroke-width="2" stroke-dasharray="5,5" opacity="0.6"/>
  <line x1="600" y1="420" x2="460" y2="340" stroke="#d4af37" stroke-width="2" stroke-dasharray="5,5" opacity="0.6"/>
  
  <!-- Shield Icon for Privacy -->
  <g transform="translate(400, 480)">
    <path d="M 0,-25 L 15,-20 L 15,0 Q 15,15 0,25 Q -15,15 -15,0 L -15,-20 Z" fill="#d4af37" opacity="0.3" stroke="#d4af37" stroke-width="2"/>
    <path d="M -5,0 L 0,8 L 10,-8" fill="none" stroke="#d4af37" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
  </g>
  
  <!-- Title -->
  <text x="400" y="540" font-family="Arial, sans-serif" font-size="36" font-weight="bold" fill="url(#gold)" text-anchor="middle">
    Federated Learning
  </text>
  <text x="400" y="575" font-family="Arial, sans-serif" font-size="18" fill="#94a3b8" text-anchor="middle">
    Privacy AI • Distributed Training • Flower
  </text>
</svg>
