<svg width="800" height="600" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="grad1" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#1e293b;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#0f172a;stop-opacity:1" />
    </linearGradient>
    <linearGradient id="gold" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" style="stop-color:#d4af37;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#f4d03f;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <!-- Background -->
  <rect width="800" height="600" fill="url(#grad1)"/>
  
  <!-- Grid Pattern -->
  <pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse">
    <path d="M 40 0 L 0 0 0 40" fill="none" stroke="#334155" stroke-width="0.5" opacity="0.3"/>
  </pattern>
  <rect width="800" height="600" fill="url(#grid)"/>
  
  <!-- Resume Document -->
  <g transform="translate(120, 150)">
    <rect x="0" y="0" width="200" height="260" rx="10" fill="#0f172a" stroke="url(#gold)" stroke-width="3"/>
    <rect x="20" y="20" width="60" height="60" rx="30" fill="#1e293b" stroke="#d4af37" stroke-width="2"/>
    <line x1="20" y1="100" x2="180" y2="100" stroke="#475569" stroke-width="3"/>
    <line x1="20" y1="120" x2="160" y2="120" stroke="#475569" stroke-width="2"/>
    <line x1="20" y1="135" x2="170" y2="135" stroke="#475569" stroke-width="2"/>
    <line x1="20" y1="160" x2="180" y2="160" stroke="#d4af37" stroke-width="3"/>
    <line x1="20" y1="180" x2="150" y2="180" stroke="#475569" stroke-width="2"/>
    <line x1="20" y1="195" x2="165" y2="195" stroke="#475569" stroke-width="2"/>
    <line x1="20" y1="210" x2="140" y2="210" stroke="#475569" stroke-width="2"/>
    <line x1="20" y1="225" x2="160" y2="225" stroke="#475569" stroke-width="2"/>
  </g>
  
  <!-- AI Brain with Connections -->
  <g transform="translate(400, 280)">
    <circle cx="0" cy="0" r="50" fill="#d4af37" opacity="0.2"/>
    <circle cx="0" cy="0" r="45" fill="none" stroke="#d4af37" stroke-width="3"/>
    <!-- Neural Network Pattern -->
    <circle cx="-20" cy="-15" r="5" fill="#d4af37"/>
    <circle cx="20" cy="-15" r="5" fill="#d4af37"/>
    <circle cx="-25" cy="10" r="5" fill="#d4af37"/>
    <circle cx="0" cy="15" r="5" fill="#d4af37"/>
    <circle cx="25" cy="10" r="5" fill="#d4af37"/>
    <line x1="-20" y1="-15" x2="0" y2="15" stroke="#d4af37" stroke-width="2" opacity="0.5"/>
    <line x1="20" y1="-15" x2="0" y2="15" stroke="#d4af37" stroke-width="2" opacity="0.5"/>
    <line x1="-25" y1="10" x2="0" y2="15" stroke="#d4af37" stroke-width="2" opacity="0.5"/>
    <line x1="25" y1="10" x2="0" y2="15" stroke="#d4af37" stroke-width="2" opacity="0.5"/>
  </g>
  
  <!-- Job Listings -->
  <g transform="translate(480, 150)">
    <rect x="0" y="0" width="200" height="80" rx="10" fill="#0f172a" stroke="#d4af37" stroke-width="2"/>
    <rect x="10" y="15" width="50" height="50" rx="5" fill="#1e293b"/>
    <line x1="70" y1="25" x2="180" y2="25" stroke="#d4af37" stroke-width="3"/>
    <line x1="70" y1="40" x2="160" y2="40" stroke="#475569" stroke-width="2"/>
    <line x1="70" y1="55" x2="170" y2="55" stroke="#475569" stroke-width="2"/>
    
    <rect x="0" y="95" width="200" height="80" rx="10" fill="#0f172a" stroke="#475569" stroke-width="2"/>
    <rect x="10" y="110" width="50" height="50" rx="5" fill="#1e293b"/>
    <line x1="70" y1="120" x2="180" y2="120" stroke="#475569" stroke-width="2"/>
    <line x1="70" y1="135" x2="160" y2="135" stroke="#475569" stroke-width="2"/>
    <line x1="70" y1="150" x2="170" y2="150" stroke="#475569" stroke-width="2"/>
    
    <rect x="0" y="190" width="200" height="80" rx="10" fill="#0f172a" stroke="#475569" stroke-width="2"/>
    <rect x="10" y="205" width="50" height="50" rx="5" fill="#1e293b"/>
    <line x1="70" y1="215" x2="180" y2="215" stroke="#475569" stroke-width="2"/>
    <line x1="70" y1="230" x2="160" y2="230" stroke="#475569" stroke-width="2"/>
    <line x1="70" y1="245" x2="170" y2="245" stroke="#475569" stroke-width="2"/>
  </g>
  
  <!-- Connection Lines -->
  <line x1="320" y1="280" x2="350" y2="280" stroke="#d4af37" stroke-width="2" stroke-dasharray="5,5" opacity="0.7"/>
  <line x1="450" y1="280" x2="480" y2="190" stroke="#d4af37" stroke-width="2" stroke-dasharray="5,5" opacity="0.7"/>
  
  <!-- Title -->
  <text x="400" y="500" font-family="Arial, sans-serif" font-size="32" font-weight="bold" fill="url(#gold)" text-anchor="middle">
    Job Search Assistant
  </text>
  <text x="400" y="540" font-family="Arial, sans-serif" font-size="18" fill="#94a3b8" text-anchor="middle">
    GenAI • Semantic Embeddings • FAISS
  </text>
</svg>
