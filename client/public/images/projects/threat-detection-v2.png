<svg width="800" height="600" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="grad1" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#1e293b;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#0f172a;stop-opacity:1" />
    </linearGradient>
    <linearGradient id="gold" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" style="stop-color:#d4af37;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#f4d03f;stop-opacity:1" />
    </linearGradient>
    <linearGradient id="danger" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" style="stop-color:#ef4444;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#dc2626;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <!-- Background -->
  <rect width="800" height="600" fill="url(#grad1)"/>
  
  <!-- Grid Pattern -->
  <pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse">
    <path d="M 40 0 L 0 0 0 40" fill="none" stroke="#334155" stroke-width="0.5" opacity="0.3"/>
  </pattern>
  <rect width="800" height="600" fill="url(#grid)"/>
  
  <!-- Shield with Warning -->
  <g transform="translate(250, 280)">
    <path d="M 0,-100 L 70,-75 L 70,-10 Q 70,40 0,80 Q -70,40 -70,-10 L -70,-75 Z" 
          fill="#0f172a" stroke="url(#gold)" stroke-width="4"/>
    <!-- Warning Triangle -->
    <path d="M 0,-50 L 35,30 L -35,30 Z" fill="#ef4444" opacity="0.2" stroke="#ef4444" stroke-width="3"/>
    <text x="0" y="25" font-family="Arial, sans-serif" font-size="50" font-weight="bold" fill="#ef4444" text-anchor="middle">!</text>
  </g>
  
  <!-- Phishing Hook -->
  <g transform="translate(550, 220)">
    <!-- Hook -->
    <path d="M 0,0 L 0,60 Q 0,80 20,80 Q 40,80 40,60 L 40,40" 
          fill="none" stroke="#ef4444" stroke-width="4" stroke-linecap="round"/>
    <circle cx="40" cy="35" r="8" fill="#ef4444"/>
    
    <!-- Email/Link -->
    <rect x="-50" y="-40" width="100" height="25" rx="5" fill="#1e293b" stroke="#ef4444" stroke-width="2"/>
    <line x1="-40" y1="-30" x2="-20" y2="-20" stroke="#ef4444" stroke-width="2"/>
    <line x1="40" y1="-30" x2="20" y2="-20" stroke="#ef4444" stroke-width="2"/>
    <line x1="-20" y1="-20" x2="20" y2="-20" stroke="#ef4444" stroke-width="2"/>
  </g>
  
  <!-- ML Detection Brain -->
  <g transform="translate(400, 420)">
    <circle cx="0" cy="0" r="60" fill="#d4af37" opacity="0.1" stroke="#d4af37" stroke-width="3"/>
    <!-- Neural connections -->
    <g opacity="0.7">
      <circle cx="-30" cy="-20" r="6" fill="#d4af37"/>
      <circle cx="30" cy="-20" r="6" fill="#d4af37"/>
      <circle cx="-40" cy="10" r="6" fill="#d4af37"/>
      <circle cx="0" cy="15" r="6" fill="#d4af37"/>
      <circle cx="40" cy="10" r="6" fill="#d4af37"/>
      <circle cx="-15" cy="35" r="6" fill="#d4af37"/>
      <circle cx="15" cy="35" r="6" fill="#d4af37"/>
      
      <line x1="-30" y1="-20" x2="0" y2="15" stroke="#d4af37" stroke-width="2" opacity="0.4"/>
      <line x1="30" y1="-20" x2="0" y2="15" stroke="#d4af37" stroke-width="2" opacity="0.4"/>
      <line x1="-40" y1="10" x2="-15" y2="35" stroke="#d4af37" stroke-width="2" opacity="0.4"/>
      <line x1="40" y1="10" x2="15" y2="35" stroke="#d4af37" stroke-width="2" opacity="0.4"/>
      <line x1="0" y1="15" x2="-15" y2="35" stroke="#d4af37" stroke-width="2" opacity="0.4"/>
      <line x1="0" y1="15" x2="15" y2="35" stroke="#d4af37" stroke-width="2" opacity="0.4"/>
    </g>
    <text x="0" y="8" font-family="Arial, sans-serif" font-size="16" font-weight="bold" fill="#d4af37" text-anchor="middle">ML</text>
  </g>
  
  <!-- Scan Lines -->
  <line x1="330" y1="250" x2="400" y2="360" stroke="#d4af37" stroke-width="2" stroke-dasharray="5,5" opacity="0.5"/>
  <line x1="520" y1="260" x2="400" y2="360" stroke="#ef4444" stroke-width="2" stroke-dasharray="5,5" opacity="0.5"/>
  
  <!-- Detection Alerts -->
  <g transform="translate(600, 380)">
    <rect x="0" y="0" width="140" height="40" rx="8" fill="#0f172a" stroke="#ef4444" stroke-width="2"/>
    <text x="20" y="26" font-family="Arial, sans-serif" font-size="16" font-weight="bold" fill="#ef4444">THREAT</text>
    <circle cx="120" cy="20" r="8" fill="#ef4444">
      <animate attributeName="opacity" values="1;0.3;1" dur="1.5s" repeatCount="indefinite"/>
    </circle>
  </g>
  
  <!-- Title -->
  <text x="400" y="540" font-family="Arial, sans-serif" font-size="36" font-weight="bold" fill="url(#gold)" text-anchor="middle">
    Phishing URL Detector
  </text>
  <text x="400" y="575" font-family="Arial, sans-serif" font-size="18" fill="#94a3b8" text-anchor="middle">
    Machine Learning • Security • Python
  </text>
</svg>
