<svg width="800" height="600" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="grad1" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#1e293b;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#0f172a;stop-opacity:1" />
    </linearGradient>
    <linearGradient id="gold" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" style="stop-color:#d4af37;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#f4d03f;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <!-- Background -->
  <rect width="800" height="600" fill="url(#grad1)"/>
  
  <!-- Grid Pattern -->
  <pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse">
    <path d="M 40 0 L 0 0 0 40" fill="none" stroke="#334155" stroke-width="0.5" opacity="0.3"/>
  </pattern>
  <rect width="800" height="600" fill="url(#grid)"/>
  
  <!-- SDN Controller (Central) -->
  <g transform="translate(400, 200)">
    <rect x="-80" y="-50" width="160" height="100" rx="15" fill="#0f172a" stroke="url(#gold)" stroke-width="4"/>
    <text x="0" y="-10" font-family="Arial, sans-serif" font-size="20" font-weight="bold" fill="#d4af37" text-anchor="middle">SDN</text>
    <text x="0" y="15" font-family="Arial, sans-serif" font-size="16" font-weight="bold" fill="#d4af37" text-anchor="middle">Controller</text>
    <circle cx="-50" cy="25" r="4" fill="#10b981">
      <animate attributeName="opacity" values="1;0.3;1" dur="2s" repeatCount="indefinite"/>
    </circle>
    <circle cx="-35" cy="25" r="4" fill="#10b981">
      <animate attributeName="opacity" values="1;0.3;1" dur="2s" begin="0.3s" repeatCount="indefinite"/>
    </circle>
    <circle cx="-20" cy="25" r="4" fill="#10b981">
      <animate attributeName="opacity" values="1;0.3;1" dur="2s" begin="0.6s" repeatCount="indefinite"/>
    </circle>
  </g>
  
  <!-- Network Switches/Routers -->
  <g transform="translate(200, 380)">
    <rect x="-50" y="-30" width="100" height="60" rx="8" fill="#1e293b" stroke="#475569" stroke-width="2"/>
    <circle cx="-30" cy="0" r="8" fill="#3b82f6" opacity="0.5"/>
    <circle cx="0" cy="0" r="8" fill="#3b82f6" opacity="0.5"/>
    <circle cx="30" cy="0" r="8" fill="#3b82f6" opacity="0.5"/>
    <text x="0" y="-40" font-family="Arial, sans-serif" font-size="12" fill="#94a3b8" text-anchor="middle">Switch 1</text>
  </g>
  
  <g transform="translate(400, 380)">
    <rect x="-50" y="-30" width="100" height="60" rx="8" fill="#1e293b" stroke="#475569" stroke-width="2"/>
    <circle cx="-30" cy="0" r="8" fill="#3b82f6" opacity="0.5"/>
    <circle cx="0" cy="0" r="8" fill="#3b82f6" opacity="0.5"/>
    <circle cx="30" cy="0" r="8" fill="#3b82f6" opacity="0.5"/>
    <text x="0" y="-40" font-family="Arial, sans-serif" font-size="12" fill="#94a3b8" text-anchor="middle">Switch 2</text>
  </g>
  
  <g transform="translate(600, 380)">
    <rect x="-50" y="-30" width="100" height="60" rx="8" fill="#1e293b" stroke="#475569" stroke-width="2"/>
    <circle cx="-30" cy="0" r="8" fill="#3b82f6" opacity="0.5"/>
    <circle cx="0" cy="0" r="8" fill="#3b82f6" opacity="0.5"/>
    <circle cx="30" cy="0" r="8" fill="#3b82f6" opacity="0.5"/>
    <text x="0" y="-40" font-family="Arial, sans-serif" font-size="12" fill="#94a3b8" text-anchor="middle">Switch 3</text>
  </g>
  
  <!-- Connection Lines -->
  <line x1="350" y1="240" x2="220" y2="350" stroke="#d4af37" stroke-width="2" opacity="0.5"/>
  <line x1="400" y1="250" x2="400" y2="350" stroke="#d4af37" stroke-width="2" opacity="0.5"/>
  <line x1="450" y1="240" x2="580" y2="350" stroke="#d4af37" stroke-width="2" opacity="0.5"/>
  
  <!-- DDoS Attack Visualization -->
  <g transform="translate(120, 120)">
    <circle cx="0" cy="0" r="30" fill="#ef4444" opacity="0.2" stroke="#ef4444" stroke-width="2"/>
    <text x="0" y="-45" font-family="Arial, sans-serif" font-size="14" font-weight="bold" fill="#ef4444" text-anchor="middle">DDoS</text>
    <!-- Attack arrows -->
    <line x1="30" y1="15" x2="130" y2="80" stroke="#ef4444" stroke-width="3" stroke-dasharray="5,5" opacity="0.7"/>
    <line x1="20" y1="25" x2="140" y2="100" stroke="#ef4444" stroke-width="3" stroke-dasharray="5,5" opacity="0.5"/>
    <line x1="15" y1="30" x2="150" y2="110" stroke="#ef4444" stroke-width="3" stroke-dasharray="5,5" opacity="0.3"/>
  </g>
  
  <!-- AI Shield (XGBoost + PPO) -->
  <g transform="translate(600, 120)">
    <path d="M 0,-40 L 30,-30 L 30,5 Q 30,25 0,40 Q -30,25 -30,5 L -30,-30 Z" 
          fill="#d4af37" opacity="0.2" stroke="#d4af37" stroke-width="3"/>
    <text x="0" y="-50" font-family="Arial, sans-serif" font-size="14" font-weight="bold" fill="#d4af37" text-anchor="middle">AI</text>
    <text x="0" y="5" font-family="Arial, sans-serif" font-size="10" font-weight="bold" fill="#d4af37" text-anchor="middle">XGB</text>
    <text x="0" y="18" font-family="Arial, sans-serif" font-size="10" font-weight="bold" fill="#d4af37" text-anchor="middle">PPO</text>
    
    <!-- Mitigation -->
    <line x1="-30" y1="-10" x2="350" y2="80" stroke="#10b981" stroke-width="3" opacity="0.7"/>
  </g>
  
  <!-- Healing Symbol -->
  <g transform="translate(530, 250)">
    <circle cx="0" cy="0" r="25" fill="#10b981" opacity="0.2"/>
    <line x1="-12" y1="0" x2="12" y2="0" stroke="#10b981" stroke-width="4" stroke-linecap="round"/>
    <line x1="0" y1="-12" x2="0" y2="12" stroke="#10b981" stroke-width="4" stroke-linecap="round"/>
  </g>
  
  <!-- Title -->
  <text x="400" y="520" font-family="Arial, sans-serif" font-size="36" font-weight="bold" fill="url(#gold)" text-anchor="middle">
    Self-Healing SDN
  </text>
  <text x="400" y="555" font-family="Arial, sans-serif" font-size="18" fill="#94a3b8" text-anchor="middle">
    XGBoost • PPO RL • DDoS Mitigation
  </text>
</svg>
