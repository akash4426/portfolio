<svg width="800" height="600" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="grad1" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#1e293b;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#0f172a;stop-opacity:1" />
    </linearGradient>
    <linearGradient id="gold" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" style="stop-color:#d4af37;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#f4d03f;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <!-- Background -->
  <rect width="800" height="600" fill="url(#grad1)"/>
  
  <!-- Grid Pattern -->
  <pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse">
    <path d="M 40 0 L 0 0 0 40" fill="none" stroke="#334155" stroke-width="0.5" opacity="0.3"/>
  </pattern>
  <rect width="800" height="600" fill="url(#grid)"/>
  
  <!-- Video Frame Icon -->
  <rect x="150" y="150" width="500" height="300" rx="20" fill="#0f172a" stroke="url(#gold)" stroke-width="3"/>
  <rect x="170" y="170" width="200" height="140" rx="10" fill="#1e293b" stroke="#475569" stroke-width="2"/>
  <rect x="390" y="170" width="240" height="140" rx="10" fill="#1e293b" stroke="#475569" stroke-width="2"/>
  <rect x="170" y="330" width="460" height="80" rx="10" fill="#1e293b" stroke="#475569" stroke-width="2"/>
  
  <!-- Play Button -->
  <circle cx="270" cy="240" r="30" fill="#d4af37" opacity="0.9"/>
  <polygon points="265,225 265,255 290,240" fill="#0f172a"/>
  
  <!-- AI Brain Icon -->
  <g transform="translate(480, 220)">
    <circle cx="0" cy="0" r="40" fill="none" stroke="#d4af37" stroke-width="3" opacity="0.7"/>
    <path d="M -20,-10 Q -10,-15 0,-10 Q 10,-15 20,-10" stroke="#d4af37" stroke-width="2" fill="none" opacity="0.7"/>
    <path d="M -15,0 Q -7.5,5 0,0 Q 7.5,5 15,0" stroke="#d4af37" stroke-width="2" fill="none" opacity="0.7"/>
    <path d="M -10,10 Q -5,15 0,10 Q 5,15 10,10" stroke="#d4af37" stroke-width="2" fill="none" opacity="0.7"/>
    <circle cx="-15" cy="-8" r="3" fill="#d4af37"/>
    <circle cx="15" cy="-8" r="3" fill="#d4af37"/>
    <circle cx="0" cy="12" r="3" fill="#d4af37"/>
  </g>
  
  <!-- Connecting Lines -->
  <line x1="300" y1="240" x2="440" y2="240" stroke="#d4af37" stroke-width="2" stroke-dasharray="5,5" opacity="0.5"/>
  
  <!-- Title -->
  <text x="400" y="500" font-family="Arial, sans-serif" font-size="36" font-weight="bold" fill="url(#gold)" text-anchor="middle">
    Video RAG System
  </text>
  <text x="400" y="540" font-family="Arial, sans-serif" font-size="18" fill="#94a3b8" text-anchor="middle">
    Multimodal AI • CLIP • Gemini
  </text>
</svg>
