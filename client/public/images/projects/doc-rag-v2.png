<svg width="800" height="600" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="grad1" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#1e293b;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#0f172a;stop-opacity:1" />
    </linearGradient>
    <linearGradient id="gold" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" style="stop-color:#d4af37;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#f4d03f;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <!-- Background -->
  <rect width="800" height="600" fill="url(#grad1)"/>
  
  <!-- Grid Pattern -->
  <pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse">
    <path d="M 40 0 L 0 0 0 40" fill="none" stroke="#334155" stroke-width="0.5" opacity="0.3"/>
  </pattern>
  <rect width="800" height="600" fill="url(#grid)"/>
  
  <!-- Document Stack -->
  <g transform="translate(250, 150)">
    <rect x="30" y="30" width="240" height="280" rx="15" fill="#1e293b" stroke="#475569" stroke-width="2" opacity="0.5"/>
    <rect x="15" y="15" width="240" height="280" rx="15" fill="#1e293b" stroke="#475569" stroke-width="2" opacity="0.7"/>
    <rect x="0" y="0" width="240" height="280" rx="15" fill="#0f172a" stroke="url(#gold)" stroke-width="3"/>
    
    <!-- Document Lines -->
    <line x1="20" y1="40" x2="220" y2="40" stroke="#475569" stroke-width="3"/>
    <line x1="20" y1="60" x2="200" y2="60" stroke="#475569" stroke-width="2"/>
    <line x1="20" y1="80" x2="210" y2="80" stroke="#475569" stroke-width="2"/>
    <line x1="20" y1="100" x2="190" y2="100" stroke="#475569" stroke-width="2"/>
    <line x1="20" y1="120" x2="205" y2="120" stroke="#475569" stroke-width="2"/>
    <line x1="20" y1="140" x2="180" y2="140" stroke="#475569" stroke-width="2"/>
    <line x1="20" y1="160" x2="200" y2="160" stroke="#475569" stroke-width="2"/>
    <line x1="20" y1="180" x2="195" y2="180" stroke="#475569" stroke-width="2"/>
    
    <!-- Magnifying Glass -->
    <circle cx="170" cy="220" r="35" fill="none" stroke="#d4af37" stroke-width="4"/>
    <line x1="197" y1="247" x2="220" y2="270" stroke="#d4af37" stroke-width="4" stroke-linecap="round"/>
    <circle cx="170" cy="220" r="20" fill="#d4af37" opacity="0.2"/>
  </g>
  
  <!-- Vector Database -->
  <g transform="translate(400, 180)">
    <!-- Database Cylinders -->
    <ellipse cx="70" cy="0" rx="70" ry="15" fill="#1e293b" stroke="#d4af37" stroke-width="2"/>
    <rect x="0" y="0" width="140" height="100" fill="#1e293b"/>
    <ellipse cx="70" cy="100" rx="70" ry="15" fill="#0f172a" stroke="#d4af37" stroke-width="2"/>
    <line x1="0" y1="0" x2="0" y2="100" stroke="#d4af37" stroke-width="2"/>
    <line x1="140" y1="0" x2="140" y2="100" stroke="#d4af37" stroke-width="2"/>
    
    <!-- Vector Points -->
    <circle cx="50" cy="40" r="3" fill="#d4af37"/>
    <circle cx="70" cy="35" r="3" fill="#d4af37"/>
    <circle cx="90" cy="45" r="3" fill="#d4af37"/>
    <circle cx="40" cy="60" r="3" fill="#d4af37"/>
    <circle cx="100" cy="60" r="3" fill="#d4af37"/>
    <circle cx="70" cy="70" r="3" fill="#d4af37"/>
  </g>
  
  <!-- Arrows -->
  <path d="M 320 280 L 380 240" stroke="#d4af37" stroke-width="3" fill="none" marker-end="url(#arrowhead)" stroke-dasharray="5,5" opacity="0.7"/>
  <defs>
    <marker id="arrowhead" markerWidth="10" markerHeight="10" refX="9" refY="3" orient="auto">
      <polygon points="0 0, 10 3, 0 6" fill="#d4af37" />
    </marker>
  </defs>
  
  <!-- Title -->
  <text x="400" y="500" font-family="Arial, sans-serif" font-size="36" font-weight="bold" fill="url(#gold)" text-anchor="middle">
    Document RAG System
  </text>
  <text x="400" y="540" font-family="Arial, sans-serif" font-size="18" fill="#94a3b8" text-anchor="middle">
    NLP • Vector DB • FastAPI
  </text>
</svg>
